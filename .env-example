PORT=your_port

# --- Local API (against your machine)
# Fast: `npm run dev` → uses http://localhost:3009/api/v1.0 by default (override via .env.development / VITE_*).
# Prod-style bundle + preview:
#   cp devlocal.env.example .env.devlocal
#   npm run start:devlocal
#   # or: npm run build:local && npm run preview:devlocal

# API URLs — production / CI (e.g. Azure Static Web Apps workflow)
REACT_APP_API_BASE_URL=https://www.lcc.com.mx/api/v1.0
REACT_APP_API_BASE_URL_V2=https://www.lcc.com.mx/api/v2.0

# Optional: Logo URL (defaults to /logo.png if unset)
# REACT_APP_LOGO_URL=https://164.92.95.176/logo.png

# Optional: Public URL for assets (defaults to relative /logo.png)
# REACT_APP_PUBLIC_URL=https://164.92.95.176

# Optional: HTTPS dev server certs for Vite
# VITE_HTTPS_KEY=/absolute/path/to/key.pem
# VITE_HTTPS_CERT=/absolute/path/to/cert.pem

ICON_URL=your_icon_url

# Optional: override MQTT broker hostname on /api-ti-water (default: tiwatermqtt.eastus-1.ts.eventgrid.azure.net)
# VITE_MQTT_PUBLIC_HOSTNAME=tiwatermqtt.eastus-1.eventgrid.azure.net