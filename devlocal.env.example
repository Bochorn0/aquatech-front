# Copy into `.env.devlocal` in this repo root:
#   cp devlocal.env.example .env.devlocal
#
# Then: npm run start:devlocal (or npm run build:devlocal && npm run preview:devlocal)
#
# Override API port/host if needed:
# VITE_API_BASE_URL=http://localhost:5000/api/v1.0
# VITE_API_BASE_URL_V2=http://localhost:5000/api/v2.0

VITE_API_BASE_URL=http://localhost:3009/api/v1.0
VITE_API_BASE_URL_V2=http://localhost:3009/api/v2.0
